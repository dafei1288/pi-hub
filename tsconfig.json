{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@mariozechner/pi-ai": ["../pi-mono/packages/ai/src"],
      "@mariozechner/pi-coding-agent": ["../pi-mono/packages/coding-agent/src"],
      "@mariozechner/pi-tui": ["../pi-mono/packages/tui/src"]
    }
  },
  "include": ["extensions/**/*.ts"]
}
