  "tokenMode": "always",
  "// tokenMode options": ["always", "highContext"],
  "// tokenThreshold": 85,

  "// === Show / Hide Elements ===": "",
  "// enabled": ["model", "project", "git", "thinking", "contextBar", "elapsed", "contextFiles", "skills", "extTools", "extCmds", "tokens", "cost", "toolStats", "runningTools", "runningAgents", "lastInput", "historyHint"],
  "// disabled": ["extCmds"],

